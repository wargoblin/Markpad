#!/bin/sh
# Markpad pre-commit hook — mirrors what CI (.github/workflows/test.yml) runs.
# Activate with: git config core.hooksPath .githooks
#
# Steps:
#   1. svelte-check on the frontend
#   2. cargo check on the Rust backend
#   3. cargo test on the Rust backend
#
# Markpad has no frontend tests (see AGENTS.md), so we don't run vitest/jest.

set -e

echo "[1/3] Running svelte-check..."
npm run check
echo "       svelte-check passed."

echo "[2/3] Running cargo check..."
( cd src-tauri && cargo check )
echo "       cargo check passed."

echo "[3/3] Running cargo test..."
( cd src-tauri && cargo test )
echo "       cargo test passed."

echo "All pre-commit checks passed."
